# Enhancement mode: rules | ollama | openai | anthropic | claude-code
ENHANCER_MODE=claude-code

# Ollama (default - local, free, secure)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

# OpenAI (opt-in)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (opt-in)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-20250414

# Claude Code CLI (local only — requires claude CLI installed and authenticated; does not work in Docker)
CLAUDE_CODE_MODEL=claude-haiku-4-5-20251001